# Copy to scripts/.env for standalone use (e.g. running the collector on a
# machine without the firmware tree's include/config.h). .env is gitignored.
# Priority: real environment variables > this file > include/config.h.

MQTT_HOST=your-cluster-id.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=your-mqtt-username
MQTT_PASS=your-mqtt-password
MQTT_TOPIC_USAGE=claude/usage
MQTT_TOPIC_THINKING=claude/thinking

# Optional fallback calibration when the Claude OAuth usage endpoint is unavailable.
SESSION_BUDGET=9000000
WEEK_BUDGET=100000000



